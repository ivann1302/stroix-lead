---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.jsx';
import HeroSection from '../components/HeroSection.jsx';
import WorkSection from '../components/WorkSection.jsx';
import InteractionSection from '../components/InteractionSection.jsx';
import SystemSection from '../components/SystemSection.jsx';
import TrustSection from '../components/TrustSection.jsx';
import QuizSection from '../components/QuizSection.jsx';
import SiteFooter from '../components/SiteFooter.jsx';
import LeadModal from '../components/LeadModal.jsx';
import { getHomeSchema, pageMeta } from '../data/home';

const schema = getHomeSchema(Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString());
---

<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  image="/images/og-stroix-leads.png"
  imageAlt="Лиды для бригад по стяжке пола от Stroix Leads"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

  <SiteHeader />

  <main>
    <HeroSection client:load />
    <WorkSection />
    <InteractionSection />
    <SystemSection />
    <TrustSection />
    <QuizSection client:load />
  </main>

  <SiteFooter />
  <LeadModal client:load />
</BaseLayout>
